generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
}

// ============================================
// CORE MODELS
// ============================================

model Consortium {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String   @db.VarChar(255)
  code      String   @unique @db.VarChar(50)
  settings  Json     @default("{}")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  municipalities Municipality[]
  alertRules     AlertRule[]
  alerts         Alert[]
  users          User[]

  @@map("consortiums")
}

model Municipality {
  id               String  @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consortiumId     String? @map("consortium_id") @db.Uuid
  ibgeCode         String  @unique @map("ibge_code") @db.VarChar(7)
  name             String  @db.VarChar(255)
  stateCode        String  @map("state_code") @db.Char(2)
  population       Int?
  areaKm2          Decimal? @map("area_km2") @db.Decimal(12, 2)
  alertThresholds  Json    @default("{}") @map("alert_thresholds")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime @updatedAt @map("updated_at") @db.Timestamptz

  consortium             Consortium?               @relation(fields: [consortiumId], references: [id], onDelete: SetNull)
  precipitationObservations PrecipitationObservation[]
  alertRules             AlertRule[]
  alerts                 Alert[]
  riskAreas              RiskArea[]
  stations               Station[]

  @@index([consortiumId])
  @@map("municipalities")
}

// ============================================
// RADAR MODELS
// ============================================

model Radar {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String   @db.VarChar(100)
  code                String   @unique @db.VarChar(20)
  elevationM          Decimal? @map("elevation_m") @db.Decimal(8, 2)
  rangeKm             Int      @default(250) @map("range_km")
  scanIntervalMinutes Int      @default(10) @map("scan_interval_minutes")
  manufacturer        String?  @db.VarChar(50)
  model               String?  @db.VarChar(50)
  band                String   @default("X") @db.VarChar(10)
  status              String   @default("operational") @db.VarChar(20)
  lastScanAt          DateTime? @map("last_scan_at") @db.Timestamptz
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt           DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Location stored as lat/lng in metadata since Prisma doesn't support PostGIS natively
  latitude            Decimal  @db.Decimal(10, 7)
  longitude           Decimal  @db.Decimal(10, 7)

  scans RadarScan[]

  @@map("radars")
}

model RadarScan {
  id            BigInt   @id @default(autoincrement())
  radarId       String   @map("radar_id") @db.Uuid
  scanTime      DateTime @map("scan_time") @db.Timestamptz
  elevationAngle Decimal? @map("elevation_angle") @db.Decimal(5, 2)
  productType   String   @map("product_type") @db.VarChar(20)
  filePath      String?  @map("file_path") @db.VarChar(500)
  tilePath      String?  @map("tile_path") @db.VarChar(500)
  qualityScore  Decimal? @map("quality_score") @db.Decimal(3, 2)
  metadata      Json     @default("{}")

  radar Radar @relation(fields: [radarId], references: [id], onDelete: Cascade)

  @@index([radarId, scanTime(sort: Desc)])
  @@index([productType, scanTime(sort: Desc)])
  @@map("radar_scans")
}

// ============================================
// PRECIPITATION MODELS
// ============================================

model PrecipitationObservation {
  id              BigInt   @id @default(autoincrement())
  municipalityId  String   @map("municipality_id") @db.Uuid
  observationTime DateTime @map("observation_time") @db.Timestamptz
  source          String   @db.VarChar(20)
  sourceId        String?  @map("source_id") @db.VarChar(50)
  precipitationMm Decimal? @map("precipitation_mm") @db.Decimal(8, 2)
  reflectivityDbz Decimal? @map("reflectivity_dbz") @db.Decimal(5, 1)
  confidence      Decimal? @db.Decimal(3, 2)
  metadata        Json     @default("{}")

  municipality Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@index([municipalityId, observationTime(sort: Desc)])
  @@index([source, observationTime(sort: Desc)])
  @@map("precipitation_observations")
}

// ============================================
// ALERT MODELS
// ============================================

model AlertRule {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consortiumId    String?  @map("consortium_id") @db.Uuid
  municipalityId  String?  @map("municipality_id") @db.Uuid
  name            String   @db.VarChar(255)
  description     String?  @db.Text
  type            String   @db.VarChar(50)
  conditions      Json
  actions         Json     @default("{\"notify\": true}")
  cooldownMinutes Int      @default(30) @map("cooldown_minutes")
  isActive        Boolean  @default(true) @map("is_active")
  priority        Int      @default(5)
  createdBy       String?  @map("created_by") @db.Uuid
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  consortium   Consortium?   @relation(fields: [consortiumId], references: [id], onDelete: Cascade)
  municipality Municipality? @relation(fields: [municipalityId], references: [id], onDelete: Cascade)
  alerts       Alert[]

  @@index([consortiumId])
  @@index([municipalityId])
  @@map("alert_rules")
}

model Alert {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  consortiumId     String?   @map("consortium_id") @db.Uuid
  municipalityId   String?   @map("municipality_id") @db.Uuid
  ruleId           String?   @map("rule_id") @db.Uuid
  severity         String    @db.VarChar(20)
  type             String    @db.VarChar(50)
  title            String    @db.VarChar(255)
  description      String?   @db.Text
  triggerValue     Decimal?  @map("trigger_value") @db.Decimal(10, 2)
  thresholdValue   Decimal?  @map("threshold_value") @db.Decimal(10, 2)
  status           String    @default("active") @db.VarChar(20)
  startedAt        DateTime  @default(now()) @map("started_at") @db.Timestamptz
  endedAt          DateTime? @map("ended_at") @db.Timestamptz
  expiresAt        DateTime? @map("expires_at") @db.Timestamptz
  acknowledgedBy   String?   @map("acknowledged_by") @db.Uuid
  acknowledgedAt   DateTime? @map("acknowledged_at") @db.Timestamptz
  resolvedBy       String?   @map("resolved_by") @db.Uuid
  resolvedAt       DateTime? @map("resolved_at") @db.Timestamptz
  notificationsSent Json     @default("[]") @map("notifications_sent")
  metadata         Json      @default("{}")

  consortium   Consortium?   @relation(fields: [consortiumId], references: [id], onDelete: SetNull)
  municipality Municipality? @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  rule         AlertRule?    @relation(fields: [ruleId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([severity, startedAt(sort: Desc)])
  @@index([municipalityId, startedAt(sort: Desc)])
  @@index([consortiumId, startedAt(sort: Desc)])
  @@map("alerts")
}

// ============================================
// RISK AREAS
// ============================================

model RiskArea {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId  String    @map("municipality_id") @db.Uuid
  name            String?   @db.VarChar(255)
  riskType        String    @map("risk_type") @db.VarChar(50)
  severity        String    @default("medium") @db.VarChar(20)
  populationAtRisk Int?     @map("population_at_risk")
  source          String?   @db.VarChar(50)
  sourceId        String?   @map("source_id") @db.VarChar(100)
  validationDate  DateTime? @map("validation_date") @db.Date
  metadata        Json      @default("{}")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  municipality Municipality @relation(fields: [municipalityId], references: [id], onDelete: Cascade)

  @@index([municipalityId])
  @@index([riskType])
  @@map("risk_areas")
}

// ============================================
// EXTERNAL STATIONS
// ============================================

model Station {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code           String   @unique @db.VarChar(50)
  name           String   @db.VarChar(255)
  source         String   @db.VarChar(50)
  stationType    String?  @map("station_type") @db.VarChar(50)
  latitude       Decimal  @db.Decimal(10, 7)
  longitude      Decimal  @db.Decimal(10, 7)
  elevationM     Decimal? @map("elevation_m") @db.Decimal(8, 2)
  municipalityId String?  @map("municipality_id") @db.Uuid
  status         String   @default("active") @db.VarChar(20)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  municipality Municipality?       @relation(fields: [municipalityId], references: [id], onDelete: SetNull)
  observations StationObservation[]

  @@index([source])
  @@map("stations")
}

model StationObservation {
  id              BigInt   @id @default(autoincrement())
  stationId       String   @map("station_id") @db.Uuid
  observationTime DateTime @map("observation_time") @db.Timestamptz
  precipitationMm Decimal? @map("precipitation_mm") @db.Decimal(8, 2)
  temperatureC    Decimal? @map("temperature_c") @db.Decimal(5, 2)
  humidityPercent Decimal? @map("humidity_percent") @db.Decimal(5, 2)
  pressureHpa     Decimal? @map("pressure_hpa") @db.Decimal(7, 2)
  windSpeedMs     Decimal? @map("wind_speed_ms") @db.Decimal(5, 2)
  windDirectionDeg Int?    @map("wind_direction_deg")
  solarRadiationWm2 Decimal? @map("solar_radiation_wm2") @db.Decimal(8, 2)
  qualityFlag     Int      @default(0) @map("quality_flag")

  station Station @relation(fields: [stationId], references: [id], onDelete: Cascade)

  @@index([stationId, observationTime(sort: Desc)])
  @@map("station_observations")
}

// ============================================
// NOWCASTING
// ============================================

model ConvectiveCell {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  trackId         String   @map("track_id") @db.VarChar(50)
  detectionTime   DateTime @map("detection_time") @db.Timestamptz
  centroidLat     Decimal  @map("centroid_lat") @db.Decimal(10, 7)
  centroidLng     Decimal  @map("centroid_lng") @db.Decimal(10, 7)
  maxReflectivityDbz Decimal? @map("max_reflectivity_dbz") @db.Decimal(5, 1)
  vil             Decimal? @db.Decimal(8, 2)
  echoTopKm       Decimal? @map("echo_top_km") @db.Decimal(5, 2)
  areaKm2         Decimal? @map("area_km2") @db.Decimal(10, 2)
  velocityMs      Decimal? @map("velocity_ms") @db.Decimal(5, 2)
  directionDeg    Int?     @map("direction_deg")
  severity        String?  @db.VarChar(20)
  isActive        Boolean  @default(true) @map("is_active")
  metadata        Json     @default("{}")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([trackId, detectionTime(sort: Desc)])
  @@map("convective_cells")
}

model NowcastForecast {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  issueTime      DateTime @map("issue_time") @db.Timestamptz
  validTime      DateTime @map("valid_time") @db.Timestamptz
  leadTimeMinutes Int     @map("lead_time_minutes")
  forecastType   String   @map("forecast_type") @db.VarChar(50)
  dataPath       String?  @map("data_path") @db.VarChar(500)
  tilePath       String?  @map("tile_path") @db.VarChar(500)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@index([issueTime(sort: Desc)])
  @@index([validTime])
  @@map("nowcast_forecasts")
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id                      String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email                   String    @unique @db.VarChar(255)
  passwordHash            String    @map("password_hash") @db.VarChar(255)
  name                    String    @db.VarChar(255)
  role                    String    @db.VarChar(50)
  consortiumId            String?   @map("consortium_id") @db.Uuid
  municipalityIds         String[]  @default([]) @map("municipality_ids") @db.Uuid
  phone                   String?   @db.VarChar(20)
  avatarUrl               String?   @map("avatar_url") @db.VarChar(500)
  notificationPreferences Json      @default("{}") @map("notification_preferences")
  isActive                Boolean   @default(true) @map("is_active")
  emailVerifiedAt         DateTime? @map("email_verified_at") @db.Timestamptz
  lastLoginAt             DateTime? @map("last_login_at") @db.Timestamptz
  failedLoginAttempts     Int       @default(0) @map("failed_login_attempts")
  lockedUntil             DateTime? @map("locked_until") @db.Timestamptz
  createdAt               DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt               DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  consortium    Consortium?    @relation(fields: [consortiumId], references: [id], onDelete: SetNull)
  refreshTokens RefreshToken[]
  apiKeys       ApiKey[]
  auditLogs     AuditLog[]

  @@index([consortiumId])
  @@map("users")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model ApiKey {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  name        String    @db.VarChar(255)
  keyHash     String    @map("key_hash") @db.VarChar(255)
  permissions Json      @default("[]")
  rateLimit   Int       @default(1000) @map("rate_limit")
  lastUsedAt  DateTime? @map("last_used_at") @db.Timestamptz
  expiresAt   DateTime? @map("expires_at") @db.Timestamptz
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("api_keys")
}

// ============================================
// AUDIT
// ============================================

model AuditLog {
  id         BigInt   @id @default(autoincrement())
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityType String?  @map("entity_type") @db.VarChar(50)
  entityId   String?  @map("entity_id") @db.Uuid
  oldValues  Json?    @map("old_values")
  newValues  Json?    @map("new_values")
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(500)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@index([entityType, entityId, createdAt(sort: Desc)])
  @@map("audit_logs")
}
